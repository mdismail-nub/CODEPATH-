rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email_verified == true && (
               exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
               request.auth.token.email == 'ismailtonmoy478@gmail.com'
             ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidUser(data) {
      return data.solvedIds is list &&
             data.certificates is map &&
             (data.get('vjudgeId', '') is string) &&
             (data.get('isAdmin', false) is bool) &&
             (data.get('solvedAt', {}) is map);
    }

    function isValidCertRequest(data) {
      return data.userId is string &&
             data.userId == request.auth.uid &&
             data.userEmail is string &&
             data.userName is string &&
             data.topicSlug is string &&
             data.vjudgeId is string &&
             data.status == 'pending' &&
             data.requestedAt == request.time &&
             data.keys().hasAll(['userId', 'userEmail', 'userName', 'topicSlug', 'vjudgeId', 'status', 'requestedAt']) &&
             data.keys().size() == 7;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // Allow creation of own profile
      allow create: if isOwner(userId) && isValidUser(incoming()) && !incoming().get('isAdmin', false);
      // Allow updates to own profile, but block changing isAdmin
      allow update: if isOwner(userId) && (
        (isValidUser(incoming()) && 
         incoming().get('isAdmin', false) == existing().get('isAdmin', false) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['solvedIds', 'certificates', 'vjudgeId', 'solvedAt']))
      ) || isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn(); // Allow checking if user is admin
      allow write: if false; // Only manageable via console
    }

    match /certificate_requests/{requestId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidCertRequest(incoming()) && isValidId(requestId);
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'issuedAt']);
      allow delete: if isAdmin();
    }
  }
}
